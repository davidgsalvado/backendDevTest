#!/usr/bin/env sh
MAVEN_WRAPPER_VERSION=0.5.6
MAVEN_VERSION=3.8.6

# Maven Wrapper script for Unix-based systems

# Check if Maven is installed
if ! command -v mvn &> /dev/null
then
    echo "Maven could not be found. Downloading Maven Wrapper version $MAVEN_WRAPPER_VERSION..."
    curl -s "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/$MAVEN_WRAPPER_VERSION/maven-wrapper-$MAVEN_WRAPPER_VERSION.jar" -o .mvn/wrapper/maven-wrapper.jar
    echo "Maven Wrapper downloaded."
fi

# Execute Maven with the specified version
exec java -jar .mvn/wrapper/maven-wrapper.jar "$@"